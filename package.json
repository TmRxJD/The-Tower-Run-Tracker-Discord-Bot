{
  "name": "tracker-bot-ts",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "description": "TypeScript rewrite of the Tower Run Tracker bot",
  "main": "dist/bot.js",
  "scripts": {
    "dev": "cross-env DEPLOYMENT_MODE=dev NODE_ENV=development ts-node-dev --respawn --transpile-only src/bot.ts",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "start": "cross-env DEPLOYMENT_MODE=prod NODE_ENV=production node dist/bot.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:hourly": "ts-node src/scripts/verify-hourly-rates.ts",
    "appwrite:schema": "ts-node src/scripts/create-appwrite-schema.ts",
    "register:commands": "cross-env DEPLOYMENT_MODE=dev ts-node src/scripts/register-commands.ts"
  },
  "dependencies": {
    "@discordjs/rest": "^2.3.0",
    "@napi-rs/canvas": "^0.1.93",
    "@tmrxjd/platform": "link:../../TrackerWebsite/the-tower-run-tracker/packages/platform",
    "dexie": "^4.0.11",
    "discord-api-types": "^0.37.83",
    "discord.js": "^14.24.0",
    "dotenv": "^16.4.7",
    "indexeddb-js": "^0.0.14",
    "node-appwrite": "^14.1.0",
    "sqlite3": "^5.1.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "@napi-rs/canvas"
    ]
  }
}
