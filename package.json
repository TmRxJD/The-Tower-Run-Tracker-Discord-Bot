{
  "name": "tracker-bot-ts",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22 <23",
    "pnpm": "10.8.1"
  },
  "description": "TypeScript rewrite of the Tower Run Tracker bot",
  "keywords": [],
  "main": "dist/bot.js",
  "scripts": {
    "postinstall": "node scripts/ensure-local-platform.mjs ensure",
    "predev": "node scripts/ensure-local-platform.mjs ensure",
    "prebuild": "node scripts/ensure-local-platform.mjs ensure",
    "pretype-check": "node scripts/ensure-local-platform.mjs ensure",
    "prelint": "node scripts/ensure-local-platform.mjs ensure",
    "pretest": "node scripts/ensure-local-platform.mjs ensure",
    "platform:sync:local": "node scripts/ensure-local-platform.mjs use-local",
    "platform:use:registry": "node scripts/ensure-local-platform.mjs use-registry",
    "platform:status": "node scripts/ensure-local-platform.mjs status",
    "dev": "cross-env DEPLOYMENT_MODE=dev NODE_ENV=development ts-node-dev --respawn --transpile-only src/bot.ts",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "start": "cross-env DEPLOYMENT_MODE=prod NODE_ENV=production node dist/bot.js",
    "deploy:install": "pnpm install --frozen-lockfile",
    "deploy:preflight": "node scripts/deploy.mjs preflight",
    "deploy:env": "node scripts/deploy.mjs write-env",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest",
    "test:watch": "pnpm run test",
    "test:run": "vitest run",
    "deploy:build": "pnpm run build",
    "deploy:commands": "pnpm run register:commands:prod",
    "deploy:activate": "node scripts/deploy.mjs activate",
    "deploy:start": "pnpm run deploy:activate",
    "deploy:stop": "pnpm run pm2:stop",
    "deploy:status": "pnpm run pm2:status",
    "deploy:logs": "pnpm run pm2:logs",
    "deploy:report": "node scripts/deploy.mjs report",
    "deploy:platform:update": "node scripts/deploy.mjs update-platform",
    "verify:hourly": "ts-node src/scripts/verify-hourly-rates.ts",
    "appwrite:schema": "ts-node src/scripts/create-appwrite-schema.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "pm2 restart trackerbot --update-env",
    "pm2:refresh": "pnpm run build && pnpm run pm2:restart",
    "pm2:stop": "pm2 stop trackerbot",
    "pm2:status": "pm2 status trackerbot",
    "pm2:logs": "pm2 logs trackerbot --lines 100",
    "register:commands": "pnpm run register:commands:dev",
    "register:commands:dev": "cross-env DEPLOYMENT_MODE=dev NODE_ENV=development BOT_LOG_LEVEL=error ts-node src/scripts/register-commands.ts --mode=dev",
    "register:commands:prod": "cross-env DEPLOYMENT_MODE=prod NODE_ENV=production BOT_LOG_LEVEL=error ts-node src/scripts/register-commands.ts --mode=prod",
    "register:commands:prod:global": "cross-env DEPLOYMENT_MODE=prod NODE_ENV=production BOT_LOG_LEVEL=error ts-node src/scripts/register-commands.ts --mode=prod --global",
    "register:commands:clear:global": "cross-env DEPLOYMENT_MODE=prod NODE_ENV=production BOT_LOG_LEVEL=error ts-node src/scripts/delete-global-commands.ts"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@napi-rs/canvas": "^0.1.97",
    "@tmrxjd/platform": "0.1.9",
    "dexie": "^4.0.11",
    "discord-api-types": "^0.37.120",
    "discord.js": "^14.25.1",
    "dotenv": "^16.6.1",
    "indexeddb-js": "^0.0.14",
    "node-appwrite": "^22.1.3",
    "sqlite3": "^5.1.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.19.7",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "globals": "^15.15.0",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "@napi-rs/canvas"
    ],
    "overrides": {
      "@tmrxjd/platform": "link:../../TrackerWebsite/the-tower-run-tracker/packages/platform"
    }
  }
}
